# ==========================
# Supabase Configuration
# ==========================
# Truncate the /rest/v1/ suffix if copy pasted. e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==========================
# Database Connection
# ==========================
# Transaction connection string or session pooler string from Supabase
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ==========================
# AI Provider Configuration
# ==========================
# Set to MOCK_MODE for local mock data without hitting APIs. Set to a real sk-... key for live GPT-4o-mini generation.
OPENAI_API_KEY=MOCK_MODE

# ==========================
# Deployment Configuration
# ==========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
